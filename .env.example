# JIMS-AI local development environment template.
# Copy to .env and fill in real values. Never commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────
# Architecture:  All LLM inference → Modal services.
#                Storage           → Supabase REST (always).
#                Auth              → Supabase (always required).
#                Training          → Modal GPU functions (not Kaggle).
#                No Groq, no local sentence-transformers, no Postgres direct.
# KEY:  [required] = must be set for the subsystem to function
#       [optional] = has a working default; set to override
#       [secret]   = sensitive — never commit real values
# ─────────────────────────────────────────────────────────────────────────────

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  SUPABASE  (Postgres + Auth — always required)                          ║
# ╚══════════════════════════════════════════════════════════════════════════╝
SUPABASE_URL=https://your-project.supabase.co/rest/v1/   # [required]
SUPABASE_SERVICE_KEY=your-supabase-service-role-key       # [secret] [required]
SUPABASE_ANON_KEY=your-supabase-anon-key                  # [secret] [required]
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
JIMS_SUPABASE_DEFAULT_SCOPES=runtime:query training:read training:write feedback:write

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  NEO4J AURA  (causal graph store)                                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_GRAPH_PROVIDER=neo4j_aura
JIMS_ENABLE_NEO4J=true
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io  # [required]
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password                          # [secret] [required]
NEO4J_DATABASE=neo4j
JIMS_CAUSAL_TRAVERSAL_DEPTH=4

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  REDIS  (queue / cache)                                                  ║
# ╚══════════════════════════════════════════════════════════════════════════╝
REDIS_ENABLED=false
REDIS_URL=                              # [optional] redis://... or rediss://...
REDIS_PUBLIC_ENDPOINT=                  # [optional] host:port (Upstash pattern)
REDIS_API=                              # [optional] Upstash token
REDIS_PASSWORD=                         # [optional] password if not in REDIS_URL
JIMS_CELERY_KEY_PREFIX=jimsai_

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CLOUDFLARE R2 + VECTORIZE                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
CF_ACCOUNT_ID=your-cloudflare-account-id    # [required]
CF_TOKEN=your-cloudflare-api-token          # [secret] used by R2 and Vectorize
CF_R2_BUCKET=your-r2-bucket                 # [required]
CF_R2_ACCESS_KEY=your-r2-access-key         # [secret] [required]
CF_R2_SECRET_KEY=your-r2-secret-key         # [secret] [required]
CF_VECTORIZE_INDEX=jimsai-embeddings        # [required]
CF_VECTORIZE_API_TOKEN=your-vectorize-token # [secret] [required]
CF_VECTORIZE_DIMENSIONS=768

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CLL CONCEPT INDEX (cross-lingual recall)                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# on = merge concept-index hits into retrieval (de-LLM cross-lingual recall);
# shadow = observe only; off = disabled. The lexicon is NOT in code — it loads
# from R2 (seed/update: python experiments/concept_model/seed_lexicon.py), so
# local and deploy share one source of truth. Falls back to the repo data/ file.
JIMS_CONCEPT_INDEX=on
JIMS_LEXICON_R2_PREFIX=concept-model

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MODAL AI SERVICES                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Bearer token injected on every inter-service call (also stored in Modal Secrets)
JIMS_MODAL_API_KEY=your-modal-api-key       # [secret] [required]

# Deployed service URLs — get from `modal deploy` output
JIMS_EMBEDDING_SERVICE_URL=https://<org>--jimsai-embedding-service.modal.run      # [required]
JIMS_CLASSIFICATION_SERVICE_URL=https://<org>--jimsai-classification-service.modal.run  # [required]
JIMS_INTENT_SERVICE_URL=https://<org>--jimsai-intent-service.modal.run            # [required]
JIMS_RENDERER_SERVICE_URL=https://<org>--jimsai-renderer-service.modal.run        # [required]
JIMS_REASONING_SERVICE_URL=https://<org>--jimsai-reasoning-service.modal.run      # [required]

# Modal CLI credentials — used by `modal deploy`, NOT read by app code
MODAL_TOKEN_ID=your-modal-token-id          # [secret] [optional] CLI only
MODAL_TOKEN_SECRET=your-modal-token-secret  # [secret] [optional] CLI only

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  LLM PROVIDER (configurable T1/T2 backend)                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Backend that serves the bounded T1 (intent) and T2 (render) interfaces.
#   modal  → Modal-hosted Qwen services (URLs above) — original default
#   nvidia → NVIDIA NIM OpenAI-compatible endpoint (e.g. Llama 3.3 70B)
# Unset -> modal. Set nvidia/openai explicitly to use an OpenAI-compatible endpoint.
JIMS_LLM_PROVIDER=modal                                  # [optional] modal | nvidia | openai

# NVIDIA NIM (OpenAI-compatible) — only needed when provider is nvidia
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx             # [secret] [optional]
NVIDIA_MODEL=meta/llama-3.3-70b-instruct                 # [optional]
NVIDIA_T1_MODEL=                                          # [optional] fast intent/extraction model; defaults to NVIDIA_MODEL
NVIDIA_T2_MODEL=                                          # [optional] renderer model; defaults to NVIDIA_MODEL
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1      # [optional]
JIMS_OPENAI_JSON_MODE=false                              # [optional] strict JSON mode if model supports it

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  EMBEDDING                                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_EMBEDDING_SERVICE_TOKEN=your-modal-api-key   # same as JIMS_MODAL_API_KEY
JIMS_EMBEDDING_DIMENSIONS=768

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TIMEOUTS  (seconds)                                                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_EMBEDDING_TIMEOUT=8
JIMS_GENERATION_TIMEOUT=120
JIMS_INTENT_EMBEDDING_TIMEOUT=8
JIMS_LIVE_EMBEDDING_TIMEOUT=8
JIMS_LIVE_EMBEDDING_ATTEMPTS=1
JIMS_PROVIDER_HTTP_TIMEOUT=8
JIMS_PROVIDER_CHECK_TIMEOUT=6
JIMS_CAPABILITY_EMBEDDING_TIMEOUT=8
JIMS_CAPABILITY_CLASSIFIER_TIMEOUT=20
JIMS_INTERACTIVE_SERVICE_TIMEOUT_CAP=12
JIMS_L1_EMBEDDING_TIMEOUT=5
JIMS_EMBEDDING_MAX_ATTEMPTS=2
JIMS_MODAL_EMBEDDING_MIN_CONTAINERS=1
JIMS_MODAL_RENDERER_MIN_CONTAINERS=1
JIMS_T1_TIMEOUT=12
JIMS_T2_TIMEOUT=12
JIMS_INGESTION_OVERLAY_TIMEOUT=8
JIMS_SYNC_CLOUD_WRITES=false
JIMS_ENABLE_QUERY_CLOUD_HYDRATION=false

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  GENERATION (Modal Intent + Renderer + Reasoning services)              ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_ENABLE_LOCAL_QWEN=true                 # routes to Modal services
JIMS_LOCAL_INFERENCE_MODEL=qwen3-1.7b-instruct
JIMS_LOCAL_INFERENCE_CHAT_PATH=/generate
JIMS_LOCAL_INFERENCE_TIMEOUT=120
JIMS_LOCAL_RENDER_MODEL=qwen3-4b-instruct
JIMS_LOCAL_RENDER_CHAT_PATH=/generate
JIMS_LOCAL_RENDER_TIMEOUT=120

# T1 thinning only; T2 remains required for query rendering.
JIMS_ADAPTIVE_TRANSFORMER_THINNING=true
JIMS_T1_SKIP_CONFIDENCE=0.60

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  COST-AWARE ROUTING                                                      ║
# ╚══════════════════════════════════════════════════════════════════════════╝
# Reasoning_Service (Qwen3-8B) activates when ANY of these hold:
#   planning_depth > JIMS_REASONING_DEPTH_THRESHOLD
#   capability_confidence < JIMS_REASONING_CONFIDENCE_THRESHOLD
#   invention engine active  /  explicit model=qwen-8b
JIMS_REASONING_CONFIDENCE_THRESHOLD=0.6
JIMS_REASONING_DEPTH_THRESHOLD=3

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CAPABILITY ROUTER                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_ENABLE_SEMANTIC_CAPABILITY_ROUTER=true
JIMS_ENABLE_ZERO_SHOT_CAPABILITY_ROUTER=true
JIMS_CAPABILITY_CLASSIFIER_MODE=off
JIMS_CAPABILITY_ROUTE_ABSOLUTE_THRESHOLD=0.16
JIMS_CAPABILITY_ROUTE_RELATIVE_THRESHOLD=0.12
JIMS_CAPABILITY_ROUTE_MARGIN_THRESHOLD=0.025
JIMS_ENABLE_LLM_CAPABILITY_ROUTER=true
JIMS_CAPABILITY_CLASSIFIER_TIMEOUT=20

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  WEB SEARCH  (world_knowledge capability)                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
DUCKDUCKGO_API_ENABLED=true             # always-on free fallback
DUCKDUCKGO_INSTANT_ANSWERS=true
BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=                   # [secret] required if BRAVE_SEARCH_ENABLED=true
JIMS_WEB_SEARCH_API_KEY=
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=30

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CODING (Docker sandbox)                                                 ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_CODE_DOCS_PROVIDER=
DOCKER_ENABLED=true
DOCKER_SOCKET=npipe:////./pipe/docker_engine   # Windows; Unix: /var/run/docker.sock
DOCKER_TIMEOUT_SECONDS=30
DOCKER_MAX_MEMORY_MB=512
DOCKER_IMAGE_PYTHON=python:3.11-slim
DOCKER_IMAGE_NODEJS=node:18-slim

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MATH SOLVER (Z3 + sympy — fully local, no keys)                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝
Z3_ENABLED=true
Z3_TIMEOUT_SECONDS=10
Z3_SOLVER_STRATEGY=auto

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CREATIVE CAPABILITIES (disabled unless URL is set)                     ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_IMAGE_GENERATION_URL=              # [optional] set to enable image gen
JIMS_AUDIO_GENERATION_URL=              # [optional] set to enable audio gen
JIMS_VIDEO_GENERATION_URL=              # [optional] set to enable video gen

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  AGENTIC TASK                                                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_AGENT_EXECUTOR_ENABLED=false
JIMS_AGENT_REQUIRE_APPROVAL=true

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TRAINING (dispatches to modal_training_service.py GPU functions)       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_TRAINING_SERVICE_URL=https://jimsai-training-service.onrender.com

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  HUGGINGFACE  (Modal Secrets value — used by Modal volume population,  ║
# ║  NOT read directly by the backend app)                                  ║
# ╚══════════════════════════════════════════════════════════════════════════╝
HF_TOKEN=your-hugging-face-read-token        # [secret] [required] model downloads

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MEMORY / RESOLUTION LEARNING                                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_ENABLE_RESOLUTION_LEARNING=true
JIMS_RESOLUTION_LEARNING_MIN_CONFIDENCE=0.90
JIMS_WM_REVIEW_REQUIRED_TERMS=medical,medicine,clinical,health,legal,law,finance,financial,investment,safety,security,weapon,biohazard,critical
JIMS_KAGGLE_MAX_PANEL_ITEMS=500
JIMS_REEMBED_POLL_INTERVAL=120
JIMS_REEMBED_BATCH_SIZE=20

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  API GATEWAY                                                             ║
# ╚══════════════════════════════════════════════════════════════════════════╝
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://jimsai.vercel.app

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  PIPELINE RUNTIME                                                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_STRICT_PROVIDER_STARTUP=false
JIMS_RUNTIME_CACHE_VERSION=2026-06-07-modal-only-v1
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG_MODE=false

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  BENCHMARK / TEST SCRIPTS ONLY                                           ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_BENCHMARK_EMAIL=your-email@example.com
JIMS_BENCHMARK_PASSWORD=your-password
