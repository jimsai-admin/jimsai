# JIMS-AI production environment template.
# Inject via: Modal Secrets, Vercel env vars, Render env vars.
# Never commit real values. All secrets go in platform secret managers.
# ─────────────────────────────────────────────────────────────────────────────
# Architecture:  All LLM inference → Modal services.
#                Storage           → Supabase REST (always production).
#                Auth              → Supabase (always required).
#                Training          → Modal GPU functions.
#                No Groq, no local sentence-transformers, no Postgres direct.
# ─────────────────────────────────────────────────────────────────────────────

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  SUPABASE                                                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝
SUPABASE_URL=https://your-project.supabase.co/rest/v1/
SUPABASE_SERVICE_KEY=your-supabase-service-role-key       # [secret]
SUPABASE_ANON_KEY=your-supabase-anon-key                  # [secret]
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co/rest/v1/
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
JIMS_SUPABASE_DEFAULT_SCOPES=runtime:query training:read training:write feedback:write

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  NEO4J AURA                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_GRAPH_PROVIDER=neo4j_aura
JIMS_ENABLE_NEO4J=true
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password                        # [secret]
NEO4J_DATABASE=neo4j
JIMS_CAUSAL_TRAVERSAL_DEPTH=4

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  REDIS                                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝
REDIS_ENABLED=true
REDIS_URL=rediss://default:your-password@your-endpoint.redis.io:port
REDIS_PUBLIC_ENDPOINT=your-endpoint.redis.io:port
REDIS_API=your-upstash-token
REDIS_PASSWORD=your-redis-password
JIMS_CELERY_KEY_PREFIX=jimsai_

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CLOUDFLARE R2 + VECTORIZE                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_TOKEN=your-cloudflare-api-token                        # [secret]
CF_R2_BUCKET=your-r2-bucket
CF_R2_ACCESS_KEY=your-r2-access-key                       # [secret]
CF_R2_SECRET_KEY=your-r2-secret-key                       # [secret]
CF_VECTORIZE_INDEX=jimsai-embeddings
CF_VECTORIZE_API_TOKEN=your-vectorize-token               # [secret]
CF_VECTORIZE_DIMENSIONS=768

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MODAL AI SERVICES                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_MODAL_API_KEY=your-modal-api-key                     # [secret]
JIMS_EMBEDDING_SERVICE_URL=https://<org>--jimsai-embedding-service.modal.run
JIMS_CLASSIFICATION_SERVICE_URL=https://<org>--jimsai-classification-service.modal.run
JIMS_INTENT_SERVICE_URL=https://<org>--jimsai-intent-service.modal.run
JIMS_RENDERER_SERVICE_URL=https://<org>--jimsai-renderer-service.modal.run
JIMS_REASONING_SERVICE_URL=https://<org>--jimsai-reasoning-service.modal.run

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  EMBEDDING                                                               ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_EMBEDDING_SERVICE_TOKEN=your-modal-api-key
JIMS_EMBEDDING_DIMENSIONS=768
JIMS_EMBEDDING_HASH_FALLBACK_ENABLED=true

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TIMEOUTS  (raise for production headroom)                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_EMBEDDING_TIMEOUT=8
JIMS_GENERATION_TIMEOUT=120
JIMS_INTENT_EMBEDDING_TIMEOUT=8
JIMS_LIVE_EMBEDDING_TIMEOUT=8
JIMS_LIVE_EMBEDDING_ATTEMPTS=1
JIMS_PROVIDER_HTTP_TIMEOUT=8
JIMS_PROVIDER_CHECK_TIMEOUT=6
JIMS_CAPABILITY_EMBEDDING_TIMEOUT=8
JIMS_CAPABILITY_CLASSIFIER_TIMEOUT=20

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  GENERATION                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_ENABLE_LOCAL_QWEN=true
JIMS_LOCAL_INFERENCE_MODEL=qwen3-1.7b-instruct
JIMS_LOCAL_INFERENCE_CHAT_PATH=/generate
JIMS_LOCAL_INFERENCE_TIMEOUT=120
JIMS_LOCAL_RENDER_MODEL=qwen3-4b-instruct
JIMS_LOCAL_RENDER_CHAT_PATH=/generate
JIMS_LOCAL_RENDER_TIMEOUT=120
JIMS_ADAPTIVE_TRANSFORMER_THINNING=true
JIMS_T1_SKIP_CONFIDENCE=0.60
JIMS_T2_SKIP_CONFIDENCE=0.95

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  COST-AWARE ROUTING                                                      ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_REASONING_CONFIDENCE_THRESHOLD=0.6
JIMS_REASONING_DEPTH_THRESHOLD=3

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CAPABILITY ROUTER                                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_ENABLE_SEMANTIC_CAPABILITY_ROUTER=true
JIMS_ENABLE_ZERO_SHOT_CAPABILITY_ROUTER=true
JIMS_ENABLE_LLM_CAPABILITY_ROUTER=true
JIMS_CAPABILITY_CLASSIFIER_TIMEOUT=20

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  WEB SEARCH                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝
DUCKDUCKGO_API_ENABLED=true
DUCKDUCKGO_INSTANT_ANSWERS=true
BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=                                     # [secret] optional
JIMS_WEB_SEARCH_API_KEY=
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=30

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CODING                                                                  ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_CODE_DOCS_PROVIDER=
DOCKER_ENABLED=true
DOCKER_SOCKET=/var/run/docker.sock   # Linux production
DOCKER_TIMEOUT_SECONDS=30
DOCKER_MAX_MEMORY_MB=512
DOCKER_IMAGE_PYTHON=python:3.11-slim
DOCKER_IMAGE_NODEJS=node:18-slim

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MATH SOLVER                                                             ║
# ╚══════════════════════════════════════════════════════════════════════════╝
Z3_ENABLED=true
Z3_TIMEOUT_SECONDS=10
Z3_SOLVER_STRATEGY=auto

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CREATIVE CAPABILITIES                                                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_IMAGE_GENERATION_URL=
JIMS_AUDIO_GENERATION_URL=
JIMS_VIDEO_GENERATION_URL=

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  AGENTIC TASK                                                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_AGENT_EXECUTOR_ENABLED=false
JIMS_AGENT_REQUIRE_APPROVAL=true

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  TRAINING                                                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_TRAINING_SERVICE_URL=https://jimsai-training-service.onrender.com

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  HUGGINGFACE  (Modal Secrets value — used by Modal volume population,  ║
# ║  NOT read directly by the backend app)                                  ║
# ╚══════════════════════════════════════════════════════════════════════════╝
HF_TOKEN=your-hugging-face-read-token        # [secret]

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MEMORY / RESOLUTION LEARNING                                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_ENABLE_RESOLUTION_LEARNING=true
JIMS_RESOLUTION_LEARNING_MIN_CONFIDENCE=0.90
JIMS_KAGGLE_MAX_PANEL_ITEMS=500
JIMS_REEMBED_POLL_INTERVAL=120
JIMS_REEMBED_BATCH_SIZE=20

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  API GATEWAY                                                             ║
# ╚══════════════════════════════════════════════════════════════════════════╝
CORS_ORIGINS=https://jimsai.vercel.app

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  PIPELINE RUNTIME                                                        ║
# ╚══════════════════════════════════════════════════════════════════════════╝
JIMS_STRICT_PROVIDER_STARTUP=false
JIMS_RUNTIME_CACHE_VERSION=2026-06-07-modal-only-v1
JIMS_TYPO_CORRECTION_ENABLED=true
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG_MODE=false
