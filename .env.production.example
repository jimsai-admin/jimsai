# JIMS-AI production environment template.
# Set real values in: Vercel env vars, AWS Lambda env vars, Render env vars,
# HuggingFace Space secrets, and local .env (never commit real values).
# All variables have safe defaults so a missing optional key degrades gracefully.

# ── Core ─────────────────────────────────────────────────────────────────────
JIMS_STORAGE_BACKEND=production
JIMS_STRICT_PROVIDER_STARTUP=false
JIMS_AUTH_PROVIDER=supabase
JIMS_AUTH_REQUIRED=true
JIMS_CLOUD_AUTHORITATIVE=true
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG_MODE=false

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
POSTGRES_URL=

# ── HuggingFace embedding + inference service ────────────────────────────────
JIMS_EMBEDDING_SERVICE_URL=https://jimstechai-jimsai-embedding-service.hf.space
JIMS_EMBEDDING_SERVICE_TOKEN=your-shared-service-token
JIMS_EMBEDDING_MODEL=intfloat/multilingual-e5-small
JIMS_EMBEDDING_DIMENSIONS=768
JIMS_EMBEDDING_HASH_FALLBACK_ENABLED=true

# Raise timeouts in production — Lambda cold start + HF Space may need headroom
JIMS_INTENT_EMBEDDING_TIMEOUT=8
JIMS_LIVE_EMBEDDING_TIMEOUT=8
JIMS_PROVIDER_HTTP_TIMEOUT=8
JIMS_PROVIDER_CHECK_TIMEOUT=6

# ── Local Qwen inference ─────────────────────────────────────────────────────
JIMS_LLM_PROVIDER=local
JIMS_ENABLE_LOCAL_QWEN=true
JIMS_QWEN_SERVICE_URL=https://jimstechai-jimsai-embedding-service.hf.space
JIMS_QWEN_SERVICE_TOKEN=your-shared-service-token
JIMS_QWEN_MODEL=qwen3-1.7b-instruct
JIMS_LOCAL_INFERENCE_URL=https://jimstechai-jimsai-embedding-service.hf.space
JIMS_LOCAL_INFERENCE_API_KEY=your-shared-service-token
JIMS_LOCAL_INFERENCE_MODEL=qwen3-1.7b-instruct
JIMS_LOCAL_INFERENCE_CHAT_PATH=/v1/chat/completions
JIMS_LOCAL_INFERENCE_TIMEOUT=120
JIMS_LOCAL_RENDER_MODEL=qwen3-4b-instruct
JIMS_LOCAL_RENDER_CHAT_PATH=/v1/chat/render
JIMS_LOCAL_RENDER_TIMEOUT=120
JIMS_RENDER_AGENT_TOKEN=your-shared-service-token

# ── Capability routing ───────────────────────────────────────────────────────
JIMS_ENABLE_SEMANTIC_CAPABILITY_ROUTER=true
JIMS_ENABLE_ZERO_SHOT_CAPABILITY_ROUTER=true
JIMS_CAPABILITY_CLASSIFIER_URL=https://jimstechai-jimsai-embedding-service.hf.space
JIMS_CAPABILITY_EMBEDDING_TIMEOUT=8
JIMS_CAPABILITY_CLASSIFIER_TIMEOUT=20
JIMS_ENABLE_LLM_CAPABILITY_ROUTER=true

# ── Web search (world_knowledge capability) ──────────────────────────────────
# DuckDuckGo is always available as no-key fallback.
DUCKDUCKGO_API_ENABLED=true
DUCKDUCKGO_INSTANT_ANSWERS=true
BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=
JIMS_WEB_SEARCH_API_KEY=
WEB_SEARCH_RATE_LIMIT_PER_MINUTE=30

# ── Coding (internal sandbox always available; external optional) ─────────────
JIMS_CODE_DOCS_PROVIDER=
DOCKER_ENABLED=true
DOCKER_TIMEOUT_SECONDS=30
DOCKER_MAX_MEMORY_MB=512
DOCKER_IMAGE_PYTHON=python:3.11-slim
DOCKER_IMAGE_NODEJS=node:18-slim

# ── Symbolic math solver ──────────────────────────────────────────────────────
Z3_ENABLED=true
Z3_TIMEOUT_SECONDS=10
Z3_SOLVER_STRATEGY=auto

# ── Multimodal encoder ───────────────────────────────────────────────────────
JIMS_ENABLE_MULTIMODAL_ENCODERS=true
JIMS_MULTIMODAL_ENCODER_MODE=external
JIMS_MULTIMODAL_ENCODER_URL=https://jimstechai-jimsai-embedding-service.hf.space
JIMS_MULTIMODAL_ENCODER_API_KEY=your-shared-service-token

# ── Re-embedding worker ──────────────────────────────────────────────────────
JIMS_REEMBED_POLL_INTERVAL=120
JIMS_REEMBED_BATCH_SIZE=20

# ── Resolution learning ──────────────────────────────────────────────────────
JIMS_ENABLE_RESOLUTION_LEARNING=true
JIMS_RESOLUTION_LEARNING_MIN_CONFIDENCE=0.90

# ── Cloudflare Vectorize + R2 ────────────────────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_VECTORIZE_INDEX=jimsai-embeddings
CF_VECTORIZE_API_TOKEN=your-vectorize-token
CF_VECTORIZE_DIMENSIONS=768
CF_R2_BUCKET=your-r2-bucket
CF_R2_ACCESS_KEY=your-r2-access-key
CF_R2_SECRET_KEY=your-r2-secret-key

# ── Neo4j Aura ───────────────────────────────────────────────────────────────
JIMS_GRAPH_PROVIDER=neo4j_aura
JIMS_ENABLE_NEO4J=true
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_URL=

# ── Kaggle ───────────────────────────────────────────────────────────────────
KAGGLE_ENABLED=false
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_API_KEY=your-kaggle-api-key
KAGGLE_DATASET_OWNER=your-kaggle-username

# ── Training service ─────────────────────────────────────────────────────────
JIMS_TRAINING_SERVICE_URL=https://jimsai-training-service.onrender.com

# ── Groq (disabled — local Qwen via HF Space used instead) ───────────────────
JIMS_ALLOW_EXTERNAL_GROQ=false
GROQ_API_KEY=

# ── HuggingFace tokens ───────────────────────────────────────────────────────
HF_TOKEN=your-hugging-face-read-token
# Write token: Lambda/Render only — never Vercel frontend
HUGGING_ACESS_TOKEN=your-hugging-face-write-token

# ── Intent classifier ────────────────────────────────────────────────────────
JIMS_USE_LOCAL_SENTENCE_TRANSFORMERS=false
JIMS_TYPO_CORRECTION_ENABLED=true

# ── Pipeline runtime ─────────────────────────────────────────────────────────
JIMS_RUNTIME_CACHE_VERSION=2026-06-06-latency-math-v3

# ── HuggingFace Space secrets (set via HF Space UI, not in this file) ────────
# JIMS_RENDER_AGENT_TOKEN=<same as JIMS_EMBEDDING_SERVICE_TOKEN>
# JIMS_EMBEDDING_MODEL=intfloat/multilingual-e5-small
# JIMS_EMBEDDING_DIMENSIONS=768
# JIMS_EMBEDDING_HASH_FALLBACK_ENABLED=true
# JIMS_ACTIVE_ARTIFACT_ID=base_encoder
# JIMS_QWEN_ENABLED=true
# JIMS_QWEN_MODEL_REPO=ggml-org/Qwen3-1.7B-GGUF
# JIMS_QWEN_MODEL_FILE=Qwen3-1.7B-Q4_K_M.gguf
# JIMS_QWEN_CONTEXT=4096
# JIMS_QWEN_BATCH=64
# JIMS_QWEN_THREADS=2
# JIMS_RENDER_MODEL_REPO=Qwen/Qwen3-4B-GGUF
# JIMS_RENDER_MODEL_FILE=Qwen3-4B-Q4_K_M.gguf
# JIMS_RENDER_MODEL_NAME=qwen3-4b-instruct
# JIMS_RENDER_CONTEXT=8192
# JIMS_RENDER_BATCH=128
# JIMS_RENDER_THREADS=2
# HF_TOKEN=<hugging-face-read-token>
