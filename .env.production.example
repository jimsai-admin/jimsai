# Cloud-only JIMS-AI production runtime
JIMS_STORAGE_BACKEND=production
JIMS_STRICT_PROVIDER_STARTUP=true
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
CORS_ORIGINS=https://app.example.com

# Supabase REST storage + Supabase Auth
JIMS_AUTH_PROVIDER=supabase
JIMS_AUTH_REQUIRED=true
JIMS_SUPABASE_DEFAULT_SCOPES=runtime:query training:read training:write feedback:write
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key

# Graph provider: use Neo4j AuraDB Free first; upgrade to Professional only when paid usage is intentional.
JIMS_GRAPH_PROVIDER=neo4j_aura
JIMS_ENABLE_NEO4J=true
NEO4J_URI=neo4j+s://instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-neo4j-password
NEO4J_DATABASE=neo4j

# Redis Cloud / Celery
REDIS_API=replace-with-redis-cloud-password-or-token
REDIS_PUBLIC_ENDPOINT=host:port
REDIS_URL=rediss://default:password@host:port/0
JIMS_CELERY_KEY_PREFIX=jimsai_

# Cloudflare R2
CF_ACCOUNT_ID=replace-with-cloudflare-account-id
CF_R2_BUCKET=jimsai-files
CF_TOKEN=replace-with-cloudflare-api-token
CF_R2_ACCESS_KEY=replace-with-r2-access-key
CF_R2_SECRET_KEY=replace-with-r2-secret-key

# Cloudflare Vectorize
CF_VECTORIZE_DIMENSIONS=768
CF_VECTORIZE_INDEX=jimsai-embeddings
CF_VECTORIZE_API_TOKEN=replace-with-vectorize-write-token

# Render embedding service used by Lambda and training service for real semantic vectors.
JIMS_EMBEDDING_SERVICE_URL=https://jimsai-embedding-service.onrender.com
JIMS_EMBEDDING_SERVICE_TOKEN=replace-with-render-agent-token
JIMS_RENDER_AGENT_TOKEN=replace-with-render-agent-token
JIMS_EMBEDDING_MODEL=intfloat/multilingual-e5-small
JIMS_EMBEDDING_DIMENSIONS=768

# External multimodal encoder service
JIMS_ENABLE_MULTIMODAL_ENCODERS=true
JIMS_MULTIMODAL_ENCODER_MODE=external
JIMS_MULTIMODAL_ENCODER_URL=
JIMS_MULTIMODAL_ENCODER_API_KEY=
# KaggleHub training payload and artifact orchestration
KAGGLE_API_TOKEN=replace-with-kaggle-api-token
KAGGLE_DATASET_OWNER=replace-with-kaggle-username
JIMS_AUTO_TRAINING_ENABLED=false
JIMS_AUTO_TRAIN_MIN_SPPE_PAIRS=25
JIMS_AUTO_TRAIN_MIN_SPPE_RENDER_PAIRS=10000
JIMS_AUTO_TRAIN_MIN_MEDIA_PENDING=5
JIMS_AUTO_TRAIN_MIN_REVIEWED_PAIRS=10
JIMS_AUTO_TRAIN_MAX_AMBIGUITY_PENDING=200
JIMS_AUTO_TRAIN_MIN_RETRIEVAL_MISSES=20
JIMS_ENCODER_BASE_MODEL=intfloat/multilingual-e5-small
JIMS_SPPE_RENDERER_BASE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0

# Bounded transformer interfaces on Groq
GROQ_API_KEY=replace-with-groq-key
GROQ_GENERATOR_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=llama-3.1-8b-instant
GROQ_INTENT_MODEL=llama-3.1-8b-instant
GROQ_RENDER_MODEL=llama-3.1-8b-instant
GROQ_CANVAS_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_INVENTION_MODEL=qwen/qwen3-32b
JIMS_ENABLE_GROQ_T1=true
JIMS_ENABLE_GROQ_T2=true
JIMS_ENABLE_GROQ_CANVAS=true
JIMS_ENABLE_GROQ_INVENTION=true
JIMS_ADAPTIVE_TRANSFORMER_THINNING=true
JIMS_T1_SKIP_CONFIDENCE=0.68
JIMS_T2_SKIP_CONFIDENCE=0.82

CANVAS_MAX_TOKENS=100000
SIMULATION_TIME_BUDGET_MS=200
LOG_LEVEL=INFO
