FROM public.ecr.aws/lambda/python:3.12

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/var/task

WORKDIR ${LAMBDA_TASK_ROOT}

COPY pyproject.toml README.md ${LAMBDA_TASK_ROOT}/
COPY prototype ${LAMBDA_TASK_ROOT}/prototype
COPY services/api-gateway/app ${LAMBDA_TASK_ROOT}/app

RUN pip install --no-cache-dir -e ".[providers]" python-multipart prometheus-client sentence-transformers mangum

CMD ["app.lambda_handler.handler"]
